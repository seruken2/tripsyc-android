# Copy to keystore.properties (which is gitignored) and fill in for release builds.
# Alternatively set these as environment variables on your build machine / CI.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore tripsyc-release.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 -alias tripsyc
#
# Path can be absolute or relative to the app module.

TRIPSYC_STORE_FILE=../tripsyc-release.jks
TRIPSYC_STORE_PASSWORD=change-me
TRIPSYC_KEY_ALIAS=tripsyc
TRIPSYC_KEY_PASSWORD=change-me
