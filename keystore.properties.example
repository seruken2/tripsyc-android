# Copy to keystore.properties (which is gitignored) and fill in for release builds.
# Alternatively set these as environment variables on your build machine / CI.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore tripwave-release.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 -alias tripwave
#
# Path can be absolute or relative to the app module.

TRIPWAVE_STORE_FILE=../tripwave-release.jks
TRIPWAVE_STORE_PASSWORD=change-me
TRIPWAVE_KEY_ALIAS=tripwave
TRIPWAVE_KEY_PASSWORD=change-me
