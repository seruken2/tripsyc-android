<?xml version="1.0" encoding="utf-8"?>
<!--
  Background fill for the Tripsyc adaptive launcher icon. Flat coral
  square covering the full 108×108 canvas — the system mask handles
  the corner shape (circle / squircle / rounded rect). The previous
  version was reused as the foreground too, which is why the icon
  rendered as a coral square with no logo.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#E8654A"
        android:pathData="M0,0h108v108h-108z" />
</vector>
