<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (S+) backup + device-transfer rules. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
