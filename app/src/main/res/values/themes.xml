<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Tripsyc theme — no action bar, chalk50 status bar -->
    <style name="Theme.Tripsyc" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/chalk50</item>
        <item name="android:navigationBarColor">@color/chalk50</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:colorBackground">@color/chalk50</item>
    </style>
</resources>
